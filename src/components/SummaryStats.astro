---
import type { Status } from '../lib/types';
interface Props { counts: Record<Status, number>; interactive?: boolean }
// interactive (default true): clickable filter buttons wired to board.ts (homepage).
// false: plain, non-focusable stats (lab pages, which have no board to filter).
const { counts, interactive = true } = Astro.props;
const ITEMS: { key: Status; label: string }[] = [
  { key: 'overdue', label: 'Overdue now' },
  { key: 'upcoming', label: 'Upcoming' },
  { key: 'missed', label: 'Missed' },
  { key: 'met', label: 'Met' },
  { key: 'partial', label: 'Partial' },
  { key: 'pending', label: 'Pending' },
];
---
<div class="summary">
  {ITEMS.map(({ key, label }) => (interactive ? (
    <div class={`stat stat--${key}`} data-stat={key} data-filter-status={key} role="button" tabindex="0"
         aria-label={`Filter the board to ${label}`}>
      <span class="stat__n" data-stat-n={key}>{counts[key]}</span>
      <span class="stat__label">{label}</span>
    </div>
  ) : (
    <div class={`stat stat--${key}`} data-stat={key}>
      <span class="stat__n" data-stat-n={key}>{counts[key]}</span>
      <span class="stat__label">{label}</span>
    </div>
  )))}
</div>
{interactive && <p class="summary-hint" aria-hidden="true">Tap any metric to filter the board</p>}
