---
import { COMMITMENTS } from '../data/commitments';
import { sortByUrgency, computeStatus, summarize } from '../lib/status';
import { commitmentsByLab } from '../lib/labs';
import { UPDATES } from '../data/updates';
import { sortUpdates } from '../lib/updates';
import { absUrl } from '../lib/urls';
import { CANONICAL_ORIGIN } from '../lib/site';
import Subscribe from '../components/Subscribe.astro';
import CommitmentCard from '../components/CommitmentCard.astro';
import LabCard from '../components/LabCard.astro';
import RegulatoryItem from '../components/RegulatoryItem.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

const now = Date.now();
const labRows = COMMITMENTS.filter((c) => c.track === 'lab');
const regulatoryRows = COMMITMENTS.filter((c) => c.track === 'regulatory' && c.deadlineType === 'calendar' && c.deadline != null)
  .sort((a, b) => (a.deadline ?? '').localeCompare(b.deadline ?? ''));
const sorted = sortByUrgency(labRows, now);
const overdue = sorted.filter((c) => computeStatus(c, now) === 'overdue');
const upcomingCount = labRows.filter((c) => computeStatus(c, now) === 'upcoming').length;
const labEntries = [...commitmentsByLab(labRows).entries()]
  .map(([lab, rows]) => ({ lab, rows, c: summarize(rows, now) }))
  .sort((a, b) => b.c.overdue - a.c.overdue || b.c.upcoming - a.c.upcoming || b.rows.length - a.rows.length);
const updated = new Date(now).toISOString().slice(0, 10);
const withBase = (p: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const latest = sortUpdates(UPDATES).slice(0, 2);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg?v=2`} />
    <title>Overdue — Frontier AI Safety Commitment Tracker</title>
    <meta name="description" content="Which dated frontier-AI-safety commitments are being kept, and which are overdue right now? A per-commitment, source-cited tracker." />
    <link rel="alternate" type="application/rss+xml" title="Overdue updates" href={absUrl('/feed.xml')} />
    <link rel="canonical" href={`${CANONICAL_ORIGIN}/`} />
  </head>
  <body>
    <Nav />
    <header class="masthead masthead--home">
      <h1>Overdue</h1>
      <p class="tagline">Are frontier AI labs keeping the dated safety promises <em>they</em> made? A per-promise, source-cited tracker.</p>
      <p class="meta">{labRows.length} lab promises · {regulatoryRows.length} regulatory · updated {updated} ·
        <a href={withBase('updates')}>Updates</a> ·
        <a href={withBase('methodology')}>Methodology</a> ·
        <a href="https://github.com/kayadibi1/overdue-ai">GitHub</a> ·
        <a href={withBase('commitments.json')}>Open data (JSON)</a> ·
        <a href={absUrl('/feed.xml')}>RSS</a>
      </p>
    </header>

    <main>

      {overdue.length > 0 ? (
        <section class="overdue-hero" aria-label="Overdue right now">
          <h2 class="eyebrow eyebrow--alert">⚠ Overdue right now · {overdue.length}</h2>
          <div class="board">{overdue.map((c) => <CommitmentCard c={c} now={now} />)}</div>
        </section>
      ) : (
        <section class="overdue-hero overdue-hero--clear" aria-label="Overdue status">
          <p>✓ Nothing overdue right now — {upcomingCount} deadline{upcomingCount === 1 ? '' : 's'} coming up.</p>
        </section>
      )}

      <section class="labs-section" aria-label="By lab">
        <div class="section-head">
          <h2>By lab</h2>
          <a href={withBase('/table')}>View all {labRows.length} as a table ↗</a>
        </div>
        <div class="labgrid">
          {labEntries.map(({ lab, rows }) => <LabCard lab={lab} rows={rows} now={now} />)}
        </div>
      </section>

      <section class="reg-section" aria-label="Upcoming regulatory milestones">
        <h2>Upcoming regulatory milestones</h2>
        <p class="reg-note">Context, not scored. These are <strong>laws</strong> (e.g. the EU AI Act), not promises a lab made — shown as countdowns, never marked "missed".</p>
        <div class="reg-grid">
          {regulatoryRows.map((c) => <RegulatoryItem c={c} now={now} />)}
        </div>
      </section>

      <section class="updates-teaser" aria-label="Latest updates">
        <h2>Latest updates</h2>
        <ul>
          {latest.map((u) => <li><a href={withBase(`/updates#${u.id}`)}>{u.title}</a> <span class="u-date">{u.date}</span></li>)}
        </ul>
        <p><a href={withBase('updates')}>All updates</a> · <a href={absUrl('/feed.xml')}>RSS</a></p>
      </section>

      <section class="cta-band" aria-label="Subscribe to updates">
        <h2>Hold them to it.</h2>
        <p>One email when a tracked deadline flips overdue, or a ruling changes. No spam.</p>
        <Subscribe />
      </section>
    </main>

    <footer class="footer">
      <p>Independent, best-effort, and unaffiliated with any lab. Rulings are judgment calls; corrections welcome via a <a href="https://github.com/kayadibi1/overdue-ai/issues">GitHub issue</a> and logged on <a href={withBase('/corrections')}>Corrections</a>.</p>
      <p class="download-row">Open data (<a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>): Download <a href={withBase('/commitments.json')}>JSON</a> · <a href={withBase('/commitments.csv')}>CSV</a> · <a href={withBase('/table')}>Table</a> · <a href={withBase('/corrections')}>Corrections</a> · <a href={withBase('methodology')}>How to cite</a></p>
      <p class="diff">Per-commitment, across all labs — not a single-deadline scorecard. Builds on prior work by <a href="https://www.seoul-tracker.org/">The Midas Project</a> and <a href="https://metr.org/fsp">METR</a>.</p>
    </footer>
  </body>
</html>
